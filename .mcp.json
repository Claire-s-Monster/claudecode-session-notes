{
	"mcpServers": {
		"sequential-thinking": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			]
		},
		"task-master-ai": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"--package=task-master-ai@0.21.0",
				"task-master-ai"
			]
		},
		"git": {
			"type": "stdio",
			"command": "pixi",
			"args": [
				"run",
				"--manifest-path",
				"/home/memento/ClaudeCode/Servers/git/worktrees/feat-llm-compliance",
				"mcp-server-git",
				"--repository",
				"/home/memento/ClaudeCode/Servers/session-notes/development"
			],
			"env": {
				"MCP_SERVER_ACTIVE": "true"
			}
		},
		"pytest-analyzer": {
			"type": "stdio",
			"command": "pixi",
			"args": [
				"run",
				"--manifest-path",
				"/home/memento/ClaudeCode/Servers/pytest-analyzer/development",
				"mcp-server",
				"--project-root",
				"/home/memento/ClaudeCode/Servers/session-notes/development"
			]
		},
		"aider": {
			"type": "stdio",
			"command": "uv",
			"args": [
				"--directory",
				"/home/memento/ClaudeCode/Servers/aider/development",
				"run",
				"mcp-aider-server",
				"--server-mode",
				"stdio",
				"--current-working-dir",
				"/home/memento/ClaudeCode/Servers/session-notes/development"
			],
			"env": {
				"MCP_SERVER_ACTIVE": "true"
			}
		}
	}
}
