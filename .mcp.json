{
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "task-master-ai": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "--package=task-master-ai",
        "task-master-ai"
      ]
    },
    "git": {
      "command": "pixi",
      "args": [
        "run",
        "--manifest-path",
        "/home/memento/ClaudeCode/Servers/git/worktrees/feat-llm-compliance",
        "mcp-server-git",
        "--repository",
        "/home/memento/ClaudeCode/Servers/session-notes/development"
      ],
      "env": {
        "MCP_SERVER_ACTIVE": "true"
      }
    },
    "pytest-analyzer": {
      "command": "pixi",
      "args": [
        "run",
         "--manifest-path",
        "/home/memento/ClaudeCode/Servers/pytest-analyzer/development",
        "mcp-server",
        "--project-root",
        "/home/memento/ClaudeCode/Servers/session-notes/development"
      ]
    },
    "aider": {
      "command": "uv",
      "args": [
        "--directory",
        "/home/memento/ClaudeCode/Servers/aider/development",
        "run",
        "mcp-aider-server",
        "--server-mode",
        "stdio",
        "--current-working-dir",
        "/home/memento/ClaudeCode/Servers/session-notes/development"
      ],
      "env": {
        "MCP_SERVER_ACTIVE": "true"
      }
    },
    "session-notes": {
      "command": "pixi",
      "args": [
        "run",
        "--manifest-path",
        "/home/memento/ClaudeCode/Servers/session-notes/development",
        "mcp-server"
      ],
      "env": {
        "MCP_SERVER_ACTIVE": "true",
        "PYTHONPATH": "src"
      }
    }
  }
}
